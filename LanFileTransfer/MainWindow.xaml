<Window x:Class="LanFileTransfer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:LanFileTransfer.ViewModels"
        Title="局域网文件传输" Height="700" Width="960"
        MinHeight="500" MinWidth="800"
        WindowStartupLocation="CenterScreen"
        Icon="Assets/icon.ico"
        Background="#f5f6fa">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" Padding="20,15" Margin="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="📁" FontSize="28" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <StackPanel>
                        <TextBlock Text="局域网文件传输" FontSize="18" FontWeight="Bold" Foreground="#2c3e50"/>
                        <TextBlock FontSize="12" Foreground="#95a5a6">
                            <TextBlock.Text>
                                <MultiBinding StringFormat="与手机互传文件 · {0}">
                                    <Binding Path="ServerUrl"/>
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="📂 打开目录" Style="{StaticResource SecondaryButton}"
                            Command="{Binding OpenDownloadFolderCommand}" Margin="0,0,6,0"
                            FontSize="12" Padding="10,5" ToolTip="用资源管理器打开文件保存文件夹"/>
                    <Button Content="📂 修改目录" Style="{StaticResource SecondaryButton}"
                            Command="{Binding ChangeDownloadPathCommand}" Margin="0,0,12,0"
                            FontSize="12" Padding="10,5" ToolTip="更改文件接收目录"/>
                    <Border CornerRadius="12" Padding="8,4" Margin="0,0,12,0"
                            Background="{Binding StatusColor}" Opacity="0.15">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="8" Height="8" Fill="{Binding StatusColor}" Margin="0,0,6,0"
                                     VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding ServerStatus}" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{Binding StatusColor}"/>
                        </StackPanel>
                    </Border>

                    <Button Content="▶ 启动服务" Style="{StaticResource PrimaryButton}"
                            Command="{Binding StartServerCommand}" Margin="0,0,8,0"/>
                    <Button Content="⏹ 停止服务" Style="{StaticResource DangerButton}"
                            Command="{Binding StopServerCommand}"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="15,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="300"/>
                <ColumnDefinition Width="320"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" Margin="0,0,10,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="200"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,8">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,10">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📤 共享文件列表" FontSize="15" FontWeight="Bold"
                                           VerticalAlignment="Center"/>
                                <TextBlock FontSize="12" Foreground="#95a5a6" VerticalAlignment="Center" Margin="8,0,0,0">
                                    <Run Text="("/>
                                    <Run Text="{Binding SharedFiles.Count, Mode=OneWay}"/>
                                    <Run Text=" 个文件)"/>
                                </TextBlock>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="➕ 添加文件" Style="{StaticResource PrimaryButton}"
                                        Command="{Binding AddFilesCommand}" FontSize="12" Padding="10,5"/>
                                <Button Content="🗑 清空" Style="{StaticResource SecondaryButton}"
                                        Command="{Binding ClearFilesCommand}" FontSize="12" Padding="10,5" Margin="6,0,0,0"/>
                            </StackPanel>
                        </Grid>

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding SharedFiles}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="10,8" Margin="0,0,0,4" CornerRadius="6"
                                                Background="#f8f9fa">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Text="{Binding FileTypeIcon}" FontSize="24"
                                                           VerticalAlignment="Center" Margin="0,0,10,0"/>

                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding FileName}" FontSize="13"
                                                               FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                                    <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                                        <TextBlock Text="{Binding FileSizeDisplay}" FontSize="11"
                                                                   Foreground="#7f8c8d"/>
                                                        <TextBlock Text=" · " FontSize="11" Foreground="#bdc3c7"/>
                                                        <TextBlock Text="{Binding FileType}" FontSize="11"
                                                                   Foreground="#7f8c8d"/>
                                                    </StackPanel>
                                                </StackPanel>

                                                <Button Grid.Column="3" Content="✕" Width="28" Height="28"
                                                        FontSize="12" Foreground="#e74c3c" Background="Transparent"
                                                        BorderThickness="0" Cursor="Hand"
                                                        Command="{Binding DataContext.RemoveFileCommand,
                                                        RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}"
                                                        ToolTip="移除文件"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <TextBlock Grid.Row="1" Text="暂无共享文件，点击「添加文件」选择要共享的文件"
                                   Foreground="#bdc3c7" FontSize="14" HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Visibility="{Binding SharedFiles.Count, Converter={StaticResource ZeroToVisible}}"/>
                    </Grid>
                </Border>

                <GridSplitter Grid.Row="1" Height="4" HorizontalAlignment="Stretch" Background="Transparent"/>

                <Border Grid.Row="2" Background="White" CornerRadius="8" Padding="15">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="📋 传输记录" FontSize="15" FontWeight="Bold"/>
                            <Button Content="清空日志" Style="{StaticResource SecondaryButton}"
                                    FontSize="11" Padding="8,3" Margin="10,0,0,0"
                                    Command="{Binding ClearLogCommand}"/>
                        </StackPanel>

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding TransferLogs}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="8,6" Margin="0,0,0,2">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Text="{Binding StatusIcon}" FontSize="14"
                                                           VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                <TextBlock Grid.Column="1" Text="{Binding Icon}" FontSize="14"
                                                           VerticalAlignment="Center" Margin="0,0,6,0"/>

                                                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                                    <TextBlock FontSize="12">
                                                        <TextBlock.Text>
                                                            <MultiBinding StringFormat="{}{0} {1}">
                                                                <Binding Path="Direction"/>
                                                                <Binding Path="FileName"/>
                                                            </MultiBinding>
                                                        </TextBlock.Text>
                                                    </TextBlock>
                                                    <TextBlock FontSize="11" Foreground="#95a5a6">
                                                        <TextBlock.Text>
                                                            <MultiBinding StringFormat="{}{0} · {1}">
                                                                <Binding Path="FileSizeDisplay"/>
                                                                <Binding Path="RemoteAddress"/>
                                                            </MultiBinding>
                                                        </TextBlock.Text>
                                                    </TextBlock>
                                                </StackPanel>

                                                <TextBlock Grid.Column="3" Text="{Binding Time, StringFormat=HH:mm:ss}"
                                                           FontSize="11" Foreground="#bdc3c7" VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="📡 服务器信息" FontSize="15" FontWeight="Bold" Margin="0,0,0,12"/>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="50"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="地址" FontSize="12" Foreground="#95a5a6" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" Text="{Binding ServerUrl, Mode=OneWay}"
                                     IsReadOnly="True" Style="{StaticResource ModernTextBox}"
                                     FontSize="13" FontFamily="Consolas"/>
                        </Grid>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="50"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="端口" FontSize="12" Foreground="#95a5a6" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" Text="{Binding Port}"
                                     Style="{StaticResource ModernTextBox}" FontSize="13"/>
                        </Grid>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="50"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="本机IP" FontSize="12" Foreground="#95a5a6" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" Text="{Binding LocalIP, Mode=OneWay}"
                                     IsReadOnly="True" Style="{StaticResource ModernTextBox}"
                                     FontSize="13" FontFamily="Consolas"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="📱 手机连接" FontSize="15" FontWeight="Bold" Margin="0,0,0,12"/>
                        <TextBlock Text="手机浏览器打开上方地址即可传输文件"
                                   FontSize="12" Foreground="#7f8c8d" TextWrapping="Wrap" Margin="0,0,0,10"/>

                        <Border Background="#f8f9fa" CornerRadius="8" Padding="15"
                                HorizontalAlignment="Center">
                            <StackPanel>
                                <Image x:Name="QRCodeImage" Width="200" Height="200"
                                       RenderOptions.BitmapScalingMode="HighQuality"/>
                                <TextBlock Text="扫描二维码连接" FontSize="12"
                                           Foreground="#95a5a6" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <Border Grid.Row="2" Background="White" CornerRadius="8" Padding="15">
                    <StackPanel>
                        <TextBlock Text="⚙ 设置" FontSize="15" FontWeight="Bold" Margin="0,0,0,12"/>

                        <TextBlock Text="接收文件保存目录:" FontSize="12" Foreground="#7f8c8d" Margin="0,0,0,4"/>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Text="{Binding DownloadPath, Mode=OneWay}"
                                     IsReadOnly="True" Style="{StaticResource ModernTextBox}"
                                     FontSize="11" TextWrapping="NoWrap" VerticalScrollBarVisibility="Disabled"/>
                            <Button Grid.Column="1" Content="📂" Width="36" Height="36"
                                    Style="{StaticResource SecondaryButton}" Margin="6,0,0,0"
                                    Command="{Binding ChangeDownloadPathCommand}" ToolTip="更改目录"/>
                        </Grid>

                        <Button Command="{Binding OpenDownloadFolderCommand}" Margin="0,0,0,15">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📂" FontSize="16" Margin="0,0,8,0"/>
                                <TextBlock Text="打开接收文件夹" FontSize="13" FontWeight="SemiBold"/>
                            </StackPanel>
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
                                    <Setter Property="Padding" Value="0,12"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Separator Margin="0,0,0,12" Background="#ecf0f1"/>

                        <TextBlock Text="使用说明:" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>
                        <TextBlock FontSize="11" Foreground="#7f8c8d" TextWrapping="Wrap" LineHeight="18">
                            1. 点击「启动服务」开启文件传输服务<LineBreak/>
                            2. 确保手机和电脑在同一局域网<LineBreak/>
                            3. 手机浏览器访问上方地址<LineBreak/>
                            4. 在手机页面上传/下载文件<LineBreak/>
                            5. 也可添加文件供手机下载<LineBreak/>
                            6. 首次运行可能需要管理员权限
                        </TextBlock>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <Border Grid.Row="2" Background="White" Padding="12,8" Margin="0,1,0,0">
            <Grid>
                <TextBlock Text="💡 提示：手机和电脑需连接同一WiFi网络" FontSize="11"
                           Foreground="#95a5a6" VerticalAlignment="Center"/>
                <TextBlock HorizontalAlignment="Right" FontSize="11" Foreground="#bdc3c7"
                           VerticalAlignment="Center">
                    <Run Text="端口 "/>
                    <Run Text="{Binding Port, StringFormat={}{0}}"/>
                    <Run Text=" · 文件保存于 "/>
                    <Run Text="{Binding DownloadPath}"/>
                </TextBlock>
            </Grid>
        </Border>
    </Grid>
</Window>